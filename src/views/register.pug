doctype html
html(lang="es" data-bs-theme="dark")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Registro - Consultora HR
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
        style.
            body {
                background: linear-gradient(135deg, #1e1e2f, #2a2a40);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem 0;
            }
            .auth-card {
                background: rgba(255, 255, 255, 0.05);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 1rem;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            }
            .form-control {
                background: rgba(255, 255, 255, 0.1);
                border: 1px solid rgba(255, 255, 255, 0.2);
                color: #fff;
            }
            .form-control:focus {
                background: rgba(255, 255, 255, 0.15);
                border-color: #0d6efd;
                color: #fff;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
            }
            .btn-primary {
                background: linear-gradient(90deg, #ec008c, #fc6767);
                border: none;
            }
            .btn-primary:hover {
                background: linear-gradient(90deg, #d80073, #e55c5c);
            }
    body
        div.container
            div.row.justify-content-center
                div.col-md-8.col-lg-6
                    div.card.auth-card.p-4.p-sm-5
                        div.text-center.mb-4
                            h2.fw-bold.text-white Talento Evolutivo
                            p.text-muted Crea una nueva cuenta
                        
                        if message && message.length > 0
                            div.alert.alert-danger.alert-dismissible.fade.show(role="alert")
                                | #{message}
                                button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")
                        
                        form(action="/register" method="POST")
                            div.mb-3
                                label.form-label.text-light(for="name") Nombre completo
                                input.form-control#name(type="text" name="name" required placeholder="Ej. Juan Pérez")
                            div.mb-3
                                label.form-label.text-light(for="email") Correo Electrónico
                                input.form-control#email(type="email" name="email" required placeholder="ejemplo@correo.com")
                            div.mb-3
                                label.form-label.text-light(for="username") Usuario
                                input.form-control#username(type="text" name="username" required placeholder="Elige un nombre de usuario")
                            div.mb-3
                                label.form-label.text-light(for="password") Contraseña
                                input.form-control#password(type="password" name="password" required placeholder="Crea una contraseña segura")
                            div.d-grid.mt-4
                                button.btn.btn-primary.btn-lg.fw-bold(type="submit") Registrarse
                        
                        div.text-center.mt-4
                            p.text-muted ¿Ya tenes una cuenta? 
                                a.text-decoration-none(href="/login") Inicia Sesión acá
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
