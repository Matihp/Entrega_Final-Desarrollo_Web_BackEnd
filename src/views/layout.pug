doctype html
html(lang="es" data-bs-theme="dark")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Consultora HR - Talento Evolutivo S.A.
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    body.d-flex.flex-column.min-vh-100
        nav.navbar.navbar-expand-lg.navbar-dark.bg-secondary.shadow-sm
            div.container.align-items-center
                a.navbar-brand.fs-3.fw-bold.m-0.p-0(href="/") Talento Evolutivo
                button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav")
                    span.navbar-toggler-icon
                div.collapse.navbar-collapse#navbarNav.d-flex.align-items-center
                    ul.navbar-nav.fs-6.fw-bold.mx-auto.m-0
                        li.nav-item
                            a.nav-link(href="/") Dashboard
                        li.nav-item
                            a.nav-link(href="/empresas") Empresas
                        li.nav-item
                            a.nav-link(href="/empleados") Empleados
                        li.nav-item
                            a.nav-link(href="/novedades") Novedades
                        li.nav-item
                            a.nav-link(href="/socios") Socios
                        li.nav-item
                            a.nav-link(href="/liquidaciones") Liquidaciones
                    if user
                        div.d-flex.align-items-center.ms-lg-4.mt-3.mt-lg-0
                            span.text-light.me-3.fw-medium Hola, #{user.name || user.username}
                            a.btn.btn-outline-light.btn-sm.fw-bold(href="/logout") Cerrar Sesión
        div.container.mt-4.flex-grow-1
            block content
        
        footer.bg-secondary.text-light.py-3.mt-auto
            div.container.d-flex.flex-column.flex-md-row.justify-content-between.align-items-center
                span.fw-bold Entrega Final de Desarrollo Web Backend
                span.small.mt-2.mt-md-0 &copy; 2026 Talento Evolutivo S.A. | Desarrollado con Node.js, Express y MongoDB.
        
        //Toast para notificaciones Socket.io
        div.toast-container.position-fixed.bottom-0.end-0.p-3(style="z-index: 1055;")
            div#socketToast.toast(role="alert" aria-live="assertive" aria-atomic="true")
                div.toast-header.bg-primary.text-white
                    strong.me-auto 🔔 Alerta de Nómina
                    button.btn-close.btn-close-white(type="button" data-bs-dismiss="toast" aria-label="Close")
                div.toast-body#socketToastBody 
        
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
        script(src="/socket.io/socket.io.js")
        script.
            document.addEventListener("DOMContentLoaded", function() {
                const currentPath = window.location.pathname;
                const navLinks = document.querySelectorAll('.navbar-nav .nav-link');
                navLinks.forEach(link => {
                    const href = link.getAttribute('href');
                    if (href === currentPath || (href !== '/' && currentPath.startsWith(href))) {
                        link.classList.add('active', 'text-white');
                    }
                });

                if (typeof io !== 'undefined') {
                    const socket = io();
                    socket.on('alerta_nomina', function(data) {
                        const toastBody = document.getElementById('socketToastBody');
                        if (toastBody) {
                            toastBody.innerText = data.mensaje;
                            const toastElement = document.getElementById('socketToast');
                            const toast = new bootstrap.Toast(toastElement);
                            toast.show();
                        } else {
                            alert(data.mensaje);
                        }
                    });
                }
            });
