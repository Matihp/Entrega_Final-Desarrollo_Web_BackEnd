doctype html
html(lang="es" data-bs-theme="dark")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Consultora HR - Talento Evolutivo S.A.
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    body
        nav.navbar.navbar-expand-lg.navbar-dark.bg-secondary.shadow-sm
            div.container.align-items-center
                a.navbar-brand.fs-3.fw-bold.m-0.p-0(href="/") Talento Evolutivo
                button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav")
                    span.navbar-toggler-icon
                div.collapse.navbar-collapse#navbarNav.d-flex.align-items-center
                    ul.navbar-nav.fs-6.fw-bold.ms-auto.m-0
                        li.nav-item
                            a.nav-link(href="/") Dashboard
                        li.nav-item
                            a.nav-link(href="/empresas") Empresas
                        li.nav-item
                            a.nav-link(href="/empleados") Empleados
                        li.nav-item
                            a.nav-link(href="/novedades") Novedades
                        li.nav-item
                            a.nav-link(href="/socios") Socios
                        li.nav-item
                            a.nav-link(href="/liquidaciones") Liquidaciones
        div.container.mt-4
            block content
        
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
        script.
            document.addEventListener("DOMContentLoaded", function() {
                const currentPath = window.location.pathname;
                const navLinks = document.querySelectorAll('.navbar-nav .nav-link');
                navLinks.forEach(link => {
                    const href = link.getAttribute('href');
                    if (href === currentPath || (href !== '/' && currentPath.startsWith(href))) {
                        link.classList.add('active', 'text-white');
                    }
                });
            });
