extends ../layout

block content
    h1 Editar Liquidación
    
    div.card.mt-4
        div.card-body
            form(action=`/liquidaciones/${liquidacion.id}/editar` method="POST")
                div.mb-3
                    label.form-label Empleado
                    select.form-select(name="empleadoId" required)
                        each empleado in empleados
                            option(value=empleado.id selected=empleado.id===liquidacion.empleadoId)= empleado.nombre
                
                div.mb-3
                    label.form-label Mes de Liquidación
                    input.form-control(type="text" name="mes" value=liquidacion.mes required)
                
                div.mb-3
                    label.form-label Monto a Liquidar ($)
                    input.form-control(type="number" step="0.01" name="monto" value=liquidacion.monto min="0.01" required)
                
                button.btn.btn-primary(type="submit") Actualizar Liquidación
                a.btn.btn-secondary.ms-2(href="/liquidaciones") Cancelar
