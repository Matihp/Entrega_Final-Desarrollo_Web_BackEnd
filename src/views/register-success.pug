doctype html
html(lang="es" data-bs-theme="dark")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Registro Exitoso - Consultora HR
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
        style.
            body {
                background: linear-gradient(135deg, #1e1e2f, #2a2a40);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem 0;
            }
            .auth-card {
                background: rgba(255, 255, 255, 0.05);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 1rem;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            }
            .btn-primary {
                background: linear-gradient(90deg, #ec008c, #fc6767);
                border: none;
            }
            .btn-primary:hover {
                background: linear-gradient(90deg, #d80073, #e55c5c);
            }
            .success-icon {
                font-size: 4rem;
                color: #20c997;
                margin-bottom: 1rem;
            }
    body
        div.container
            div.row.justify-content-center
                div.col-md-6.col-lg-5
                    div.card.auth-card.p-4.p-sm-5.text-center
                        div.success-icon
                            // Checkmark SVG
                            svg(xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16")
                                path(d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z")
                        
                        h2.fw-bold.text-white ¡Registro Exitoso!
                        p.text-muted.mb-4 Tu cuenta fue creada correctamente. Ahora puedes iniciar sesión en la plataforma.
                        
                        div.d-grid
                            a.btn.btn-primary.btn-lg.fw-bold(href="/login") Ir a Iniciar Sesión
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
